                <ui:VisualElement name="RoleUIContatiner" picking-mode="Ignore" class="card-role-ui-container" style="flex-grow: 1;" />
                <ui:VisualElement name="CostContainer" class="cost-container" style="flex-grow: 1; display: none;">
                    <ui:Label text="0" name="CostLabel" class="cost-label" />
