        <ui:VisualElement name="PlayerStatus" class="PlayerStatusPanel StatusPanel" style="flex-grow: 1;">
            <ui:VisualElement name="Portrait" class="Portrait" style="flex-grow: 1;" />
            <ui:VisualElement name="StatusBar" class="LordInfoBar" style="flex-grow: 1;">
                <ui:VisualElement name="XP-Bar" class="statusbar xp-bar" style="flex-grow: 1;">
                    <ui:Label text="Label" name="LV-label" class="bar-label xp-label" />
                    <ui:VisualElement name="XP-Ticks-Container" class="xp-ticks-container" style="flex-grow: 1;">
                        <ui:VisualElement name="XPTick0" class="xp-tick" style="flex-grow: 1;" />
