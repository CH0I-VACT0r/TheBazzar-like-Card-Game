            <ui:VisualElement name="CardSlot_3" class="CardSlot" style="flex-grow: 1;">
                <ui:VisualElement name="CardImage" class="card-image-background" style="flex-grow: 1;" />
                <ui:VisualElement name="CooldownOverlay" class="card-cooldown-overlay" style="flex-grow: 1; display: none;" />
                <ui:VisualElement name="RoleUIContatiner" picking-mode="Ignore" class="card-role-ui-container" style="flex-grow: 1;" />
                <ui:VisualElement name="CostContainer" class="cost-container" style="flex-grow: 1; display: none;">
